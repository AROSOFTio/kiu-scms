# SCMS Production Environment Variables Example
# Copy this file to .env on the production server and fill in the actual values.

# 1. Database Configuration
DB_ROOT_PASSWORD=
DB_NAME=scms_db
DB_USER=kiu_user
DB_PASSWORD=

# 2. Backend Configuration
PORT=5000
JWT_SECRET=
NODE_ENV=production

# 3. Frontend Configuration (Vite base URL if needed)
VITE_API_URL=https://scms.arosoft.io/api

# 4. Nginx Proxy Configuration
DOMAIN=scms.arosoft.io
# Internal port for the frontend (8086 as requested)
EXTERNAL_PORT=8086

# 5. Email Configuration (Optional - for notifications)
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=
# FROM_EMAIL=
