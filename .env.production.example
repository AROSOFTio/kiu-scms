# ======================================================== #
#        SCMS PRODUCTION DEPLOYMENT ENVIRONMENT FILE       #
# ======================================================== #
# Instructions:
# Copy this file to `.env` in the project root before running
# `docker compose -f docker-compose.prod.yml up -d --build`

# ----------------- DATABASE CONFIGURATION -----------------
# For aaPanel MySQL running on the same server, keep DB_HOST as
# host.docker.internal and make sure docker-compose.prod.yml stays
# mapped with `host-gateway`.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=scms_db
DB_USER=kiu_user
DB_PASSWORD=SecurePasswordForKiuUser99!

# ------------------ BACKEND CONFIGURATION -----------------
# Ensure JWT_SECRET is a long, unguessable string
JWT_SECRET=YOUR_SUPER_SECRET_PRODUCTION_KEY_MIN_32_CHARS
NODE_ENV=production

# ----------------- FRONTEND CONFIGURATION -----------------
# Docker exposes the frontend container on this host port.
FRONTEND_PORT=3001
# Build-time API base URL for the React app. Keep this as /api/v1 when
# aaPanel reverse proxies the domain to the frontend container.
VITE_API_URL=/api/v1
# Public application URL for reference in deployment scripts/docs.
APP_URL=https://kiuscms.arosoft.io

# ----------------- OPTIONAL: NOTIFICATIONS ----------------
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=
