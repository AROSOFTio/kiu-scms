# ======================================================== #
#        SCMS PRODUCTION DEPLOYMENT ENVIRONMENT FILE       #
# ======================================================== #
# Instructions:
#  1. Copy this file to `.env` in the project root
#  2. Fill in your real values below
#  3. Run: bash scripts/fix-mysql-docker.sh  (once, as root)
#  4. Run: bash scripts/deploy.sh

# ----------------- DATABASE CONFIGURATION -----------------
# DB_HOST must be host.docker.internal so Docker container can
# reach aaPanel MySQL on the host. The docker-compose.prod.yml
# uses extra_hosts: host.docker.internal:host-gateway for Linux.
DB_HOST=host.docker.internal
DB_PORT=3306
# These MUST match the aaPanel database name and user exactly
DB_NAME=kiu_scms
DB_USER=kiu_scms
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# Longer timeout for aaPanel MySQL on the same host
DB_CONNECT_TIMEOUT=30000

# ------------------ BACKEND CONFIGURATION -----------------
JWT_SECRET=YOUR_SUPER_SECRET_PRODUCTION_KEY_MIN_32_CHARS_HERE
NODE_ENV=production

# ----------------- FRONTEND CONFIGURATION -----------------
# Port the Nginx frontend container is exposed on (aaPanel reverse proxy → this)
FRONTEND_PORT=3001
# Build-time API base URL — keep /api/v1 when aaPanel proxies the domain
VITE_API_URL=/api/v1
APP_URL=https://kiuscms.arosoft.io

# ----------------- OPTIONAL: EMAIL NOTIFICATIONS ----------
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=
